# RDQS input receivers are retained for hardware debug. DQ data capture uses the
# dedicated fixed RX 400M clock and does not use RDQS as an internal fabric clock.
set_property CLOCK_DEDICATED_ROUTE FALSE [get_nets {lpddr5_dut1/U_lpddr5_channel/U_lpddr5_ch_a_phy_io/U_lpddr5_dqs_serdes_phy/GEN_RDQS_IO[0].U_rdqs_iobuf/O}]
